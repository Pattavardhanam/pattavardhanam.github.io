{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo" style="background-color: var(--global-bg-color); border-top: 1px solid var(--global-divider-color); padding: 12px 0;">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6" style="font-size: 0.85rem; color: var(--global-text-color);">
          <p class="mb-0">{{ site.first_name }} {{ site.last_name }}</p>
          <a href="mailto:{{ site.email }}" style="color: #4a90d9;">{{ site.email }}</a>
        </div>
        <div class="col-md-6 text-md-end" style="font-size: 0.85rem; color: var(--global-text-color-light); font-family: monospace;">
          You don't need a lot of Δv to inspire!!
        </div>
      </div>
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo" style="background-color: var(--global-bg-color); border-top: 1px solid var(--global-divider-color); padding: 12px 0;">
    <div class="container">
      <div class="row align-items-center">
        <div class="col-md-6" style="font-size: 0.85rem; color: var(--global-text-color);">
          <p class="mb-0">{{ site.first_name }} {{ site.last_name }}</p>
          <a href="mailto:{{ site.email }}" style="color: #4a90d9;">{{ site.email }}</a>
        </div>
        <div class="col-md-6 text-md-end" style="font-size: 0.85rem; color: var(--global-text-color-light); font-family: monospace;">
          You don't need a lot of Δv to inspire!!
        </div>
      </div>
    </div>
  </footer>
{% endif %}
